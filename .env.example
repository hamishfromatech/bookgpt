# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-change-in-production
FLASK_DEBUG=true
PORT=6748

# OpenAI / LLM Configuration
# Set your OpenAI API key, or use a custom base URL for local LLMs
OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_BASE_URL=http://localhost:11434/v1  # Uncomment for Ollama
# LLM_MODEL=gpt-4o  # Or use your model name

# Stripe / Billing Configuration
# Set STRIPE_ENABLED=false to disable billing (unlimited usage)
STRIPE_ENABLED=false

# If Stripe is enabled, configure these:
# STRIPE_PUBLIC_KEY=pk_test_your_public_key
# STRIPE_SECRET_KEY=sk_test_your_secret_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# STRIPE_PRICE_ID=price_your_price_id

# Application Domain
DOMAIN=http://localhost:6748